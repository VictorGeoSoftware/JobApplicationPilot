{
  "manifest_version": 3,
  "name": "Elite Recruiter Copilot",
  "version": "1.0.0",
  "description": "AI recruiter assistant for job application questions.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Elite Recruiter Copilot",
    "default_popup": "popup.html"
  }
}
